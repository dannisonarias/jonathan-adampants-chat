# ── Required for cloud / OpenRouter ──────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Override model (default: deepseek/deepseek-v4-flash) ──────────────────────
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku
# OPENROUTER_MODEL=google/gemini-flash-1.5

# ── Local Ollama mode (disables OpenRouter entirely, no API key needed) ───────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── IP rate limiting for public deployments (free Upstash tier) ───────────────
# Sign up at https://upstash.com → create a Redis DB → copy the REST credentials
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here
